{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug server.mjs",
      "program": "${workspaceFolder}/server.mjs",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to --inspect",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
